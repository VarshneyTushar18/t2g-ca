PORT=3001

# Frontend URL(s) allowed to call this API (comma-separated, required)
# Local dev:
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
# Production example:
# CORS_ORIGIN=https://tech2globe.ca,https://www.tech2globe.ca

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Comma-separated enquiry inboxes (team notification)
LEAD_EMAILS=info@tech2globe.com,enquiries@tech2globe.net

# Optional legacy single recipient (used if LEAD_EMAILS is empty)
# MAIL_TO=info@example.com

SMTP_EMAIL=your-email@gmail.com
# MAIL_FROM="Tech2Globe <your-email@gmail.com>"

TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# MySQL (existing DB, separate table for this site)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=t2g_db
DB_USER=your-db-user
DB_PASS=your-db-password
DB_TABLE=leads_tech2globeca
# Optional
# DB_POOL_SIZE=10
